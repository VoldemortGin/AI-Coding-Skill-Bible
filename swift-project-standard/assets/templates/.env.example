# 环境变量覆盖配置(`APP_` 前缀,`__` 分隔嵌套)。复制为 `.env` 并填值。
# 优先级:默认值 < configs/settings.json < 这些环境变量。

# 装配缝:选 LLM provider。默认 mock(离线、无 key)。
APP_LLM_PROVIDER=mock

# 检索配置(覆盖 settings.json 的 retriever.topK / retriever.rerankModel)。
APP_RETRIEVER__TOP_K=5
APP_RETRIEVER__RERANK_MODEL=mock-rerank

# 真实后端 secrets(仅在 --traits RealProviders 构建时使用;切勿提交真实 key)。
# OPENAI_API_KEY=sk-...
