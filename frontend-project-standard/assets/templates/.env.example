# 环境变量(复制为 `.env` 并填值)。优先级:默认值 < configs/settings.json < 这些 env。
# 由 packages/kernel 的 config.ts 用 Zod 校验;非法即在加载时崩溃(parse, don't validate)。
# secrets 只来自 env,不入 bundle、不落日志。

# 运行环境(server schema)。
NODE_ENV=development

# 装配缝:选 LLM provider。默认 mock(离线、无 key)。
LLM_PROVIDER=mock

# 检索:召回条数(1..100;越界即拒绝加载)。
RETRIEVER_TOP_K=5

# 暴露给浏览器的公开配置(client schema,NEXT_PUBLIC_ / VITE_ 前缀皆可读)。
# 切勿把 secret 放进 NEXT_PUBLIC_ / VITE_:它们会进 bundle。
NEXT_PUBLIC_APP_NAME=__SCOPE__-app

# 真实后端 secrets(仅启用真实 adapter 时需要;切勿提交真实 key)。
# OPENAI_API_KEY=sk-...
